# Copy this file to .env and fill in real values
# Run: cp .env.example .env

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://agrosense:agrosense_dev_password@localhost:5432/agrosense

# ─── JWT Auth ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-secrets.token_urlsafe(48)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── Cloudflare R2 ─────────────────────────────────────────
# Get from: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=agrosense-photos
R2_ENDPOINT_URL=https://<your-account-id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-<random>.r2.dev

# ─── Google Gemini ─────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

 # ─── Redis ─────────────────────────────────────────────
 REDIS_URL=redis://localhost:6379/0

 # ─── Twilio ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC.-real-sid
TWILIO_AUTH_TOKEN=real-token
TWILIO_PHONE_NUMBER=+12025551234